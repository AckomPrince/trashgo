{
  "name": "trashgo-backend",
  "version": "1.0.0",
  "description": "TrashGo On-Demand Waste Pickup API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "psql $DATABASE_URL -f src/migrations/001_schema.sql",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ],
    "moduleNameMapper": {
      "config/logger$": "<rootDir>/tests/stubs/logger.js",
      "config/firebase$": "<rootDir>/tests/stubs/firebase.js"
    },
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "clearMocks": true,
    "resetMocks": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/migrations/**"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^11.11.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^3.0.3",
    "paystack-node": "^0.3.0",
    "pg": "^8.11.3",
    "socket.io": "^4.6.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
