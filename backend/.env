# ── Server ──────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/trashgo

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# ── Paystack ─────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── Firebase Admin SDK ───────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ── Cloudinary (profile / proof photos) ──────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Points Config ────────────────────────────────
POINTS_PER_PICKUP=50
POINTS_PER_KG=10
RECYCLABLE_MULTIPLIER=1.5
REDEMPTION_RATE=100       # points per GHS/USD unit
MIN_REDEMPTION_POINTS=500
PLATFORM_COMMISSION=0.20  # 20%

# ── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://admin.trashgo.app
